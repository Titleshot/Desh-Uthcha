# Copy this file to `.env` and fill in at least ONE option below.
# Restart `npm run dev` (or rebuild) after any change — Vite reads env only at startup.
#
# App order: Supabase (if URL + anon key) → Formspree → Web3Forms → mailto (last resort).

# ─────────────────────────────────────────────────────────────────────────────
# Option A — Supabase (recommended: generous free tier, you own the data)
# ─────────────────────────────────────────────────────────────────────────────
# 1. New project at https://supabase.com → Project Settings → API
# 2. Copy Project URL and anon public key into the two lines below.
# 3. SQL Editor: paste and run scripts/supabase-setup.sql
# 4. Optional: email on new rows — see comments in that SQL file (Edge Function + webhook).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Option B — Formspree (free tier: limited submissions/month, emails you — no DB)
# ─────────────────────────────────────────────────────────────────────────────
# 1. https://formspree.io — sign up, create a form, copy the form id (the part after /f/)
# 2. In form settings, make “email” optional if visitors may skip the optional email field.
# 3. Paste only the id, e.g. xpzgvjkd (or full URL — the app will strip it).
VITE_FORMSPREE_FORM_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Option C — Web3Forms (free tier ~250 submissions/month, no card — paid plans are optional)
# ─────────────────────────────────────────────────────────────────────────────
# https://web3forms.com — Access Key → paste below.
VITE_WEB3FORMS_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Option D — mailto only if nothing above is configured (not recommended)
# ─────────────────────────────────────────────────────────────────────────────
# VITE_SUBMISSION_EMAIL=
